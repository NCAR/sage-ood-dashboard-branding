<%# app/views/layouts/_org_header.html.erb %>
<%# Custom NCAR/GDEX-style org header above the OOD navbar %>

<div class="ncar-header d-print-none">
  <div class="container-lg px-4">
    <div class="row align-items-center py-2">
      <!-- Left: NCAR logo -->
      <div class="col-auto">
        <a class="d-inline-flex align-items-center text-decoration-none" href="https://ncar.ucar.edu" title="NSF NCAR Home">
          <img
            src="<%= @user_configuration.public_url%>/branding/logo-ncar.png"
            alt="NSF NCAR"
            class="ncar-header-logo img-fluid"
          >
          <span class="visually-hidden">NSF NCAR</span>
        </a>
      </div>

      <!-- Optional: add simple right-side content later -->
      <div class="col">
        <%# keep empty for now, or add a right-aligned utility later %>
      </div>
    </div>
  </div>
</div>
